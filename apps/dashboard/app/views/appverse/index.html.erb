<%- content_for :head do -%>
  <%= javascript_include_tag 'appverse', nonce: true, type: 'module' %>
<%- end -%>

<div class="appverse-page" id="appverse-page">

  <%# ─── Search & Header ─────────────────────────────────────────────────── %>
  <div class="appverse-header sticky-top bg-body border-bottom shadow-sm py-3 mb-4">
    <div class="container-fluid px-4">
      <div class="row align-items-center g-2">
        <div class="col-auto">
          <h1 class="h4 mb-0 fw-semibold">
            <i class="fas fa-th-large me-2 text-primary"></i>Appverse
          </h1>
        </div>
        <div class="col">
          <div class="input-group input-group-sm ms-2">
            <span class="input-group-text bg-transparent border-end-0">
              <i class="fas fa-search text-muted"></i>
            </span>
            <input type="search"
                   id="appverse-search"
                   class="form-control border-start-0 ps-0"
                   placeholder="Search apps..."
                   aria-label="Search apps"
                   autocomplete="off">
          </div>
        </div>
        <div class="col-auto">
          <a href="<%= classic_dashboard_path %>" class="btn btn-sm btn-outline-secondary">
            <i class="fas fa-home me-1"></i>Classic Dashboard
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="container-fluid px-4">

    <%# ─── My Installed Apps ─────────────────────────────────────────────── %>
    <section class="appverse-section mb-5" id="section-installed">
      <h2 class="h5 fw-semibold text-muted text-uppercase letter-spacing-1 mb-3">
        <i class="fas fa-check-circle text-success me-2"></i>My Apps
      </h2>

      <% if @installed_apps.empty? %>
        <div class="alert alert-light border text-muted">
          No apps are installed on this system. Ask your administrator to add apps.
        </div>
      <% else %>
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-3" id="installed-grid">
          <%- @installed_apps.each do |app| -%>
            <%- app.links.each do |link| -%>
              <div class="col appverse-item" data-title="<%= link.title.to_s.downcase %>">
                <div class="card h-100 appverse-card appverse-card--installed shadow-sm">
                  <a href="<%= link.url %>" class="card-body text-decoration-none text-reset d-flex flex-column align-items-center text-center py-4">
                    <div class="appverse-icon mb-3">
                      <% if app.svg_icon? || app.png_icon? %>
                        <img src="<%= app_icon_path(name: app.name, type: app.type.to_s) %>"
                             alt="<%= link.title %>"
                             class="appverse-icon__img"
                             onerror="this.style.display='none'; this.nextElementSibling.style.display=''">
                        <i class="fas fa-cube appverse-icon__fa" style="display:none"></i>
                      <% else %>
                        <i class="fas fa-cube appverse-icon__fa text-secondary"></i>
                      <% end %>
                    </div>
                    <span class="fw-medium appverse-card__title"><%= link.title %></span>
                    <% if app.caption.present? %>
                      <small class="text-muted mt-1 appverse-card__caption"><%= app.caption %></small>
                    <% end %>
                  </a>
                </div>
              </div>
            <%- end -%>
          <%- end -%>
        </div>

        <%# Empty state shown by JS when search yields no installed matches %>
        <p class="text-muted fst-italic d-none" id="installed-empty-state">
          No installed apps match your search.
        </p>
      <% end %>
    </section>

    <%# ─── Divider ────────────────────────────────────────────────────────── %>
    <hr class="my-4">

    <%# ─── Community Catalog ──────────────────────────────────────────────── %>
    <section class="appverse-section mb-5" id="section-catalog">
      <div class="d-flex align-items-baseline gap-3 mb-3">
        <h2 class="h5 fw-semibold text-muted text-uppercase letter-spacing-1 mb-0">
          <i class="fas fa-globe text-primary me-2"></i>Community Catalog
        </h2>
        <small class="text-muted">
          Powered by
          <a href="https://openondemand.connectci.org/appverse" target="_blank" rel="noopener">
            openondemand.connectci.org
          </a>
        </small>
      </div>

      <% if @catalog_error %>
        <div class="alert alert-warning d-flex align-items-center gap-2">
          <i class="fas fa-exclamation-triangle"></i>
          <span>
            The Appverse catalog could not be loaded. Check your internet connectivity or try refreshing.
          </span>
        </div>
      <% else %>
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-3" id="catalog-grid">
          <%- @catalog_apps.each do |app| -%>
            <% already_installed = @installed_title_set.include?(app.title.downcase) %>
            <div class="col appverse-item" data-title="<%= app.title.downcase %>">
              <div class="card h-100 appverse-card shadow-sm <%= 'appverse-card--installed' if already_installed %>">
                <div class="card-body d-flex flex-column align-items-center text-center py-4">
                  <div class="appverse-icon mb-3">
                    <i class="fas fa-cube appverse-icon__fa text-secondary"></i>
                  </div>
                  <span class="fw-medium appverse-card__title"><%= app.title %></span>
                  <% if already_installed %>
                    <span class="badge bg-success-subtle text-success-emphasis mt-1">Installed</span>
                  <% end %>
                  <p class="text-muted small mt-2 appverse-card__description">
                    <%= truncate(app.description_text, length: 100) %>
                  </p>
                </div>
                <div class="card-footer bg-transparent border-0 d-flex justify-content-center gap-2 pb-3">
                  <% if app.website_url.present? %>
                    <a href="<%= app.website_url %>"
                       target="_blank"
                       rel="noopener"
                       class="btn btn-sm btn-outline-primary">
                      <i class="fas fa-external-link-alt me-1"></i>Learn More
                    </a>
                  <% end %>
                </div>
              </div>
            </div>
          <%- end -%>
        </div>

        <p class="text-muted fst-italic d-none" id="catalog-empty-state">
          No catalog apps match your search.
        </p>
      <% end %>
    </section>

  </div><%# /container-fluid %>
</div><%# /appverse-page %>
